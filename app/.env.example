# WhaSender Environment Variables

# ===================================
# Publishing Configuration
# ===================================

# GitHub Personal Access Token (for publishing releases)
# Get from: https://github.com/settings/tokens
# Scopes needed: repo (full access)
GH_TOKEN=ghp_your_publishing_token_here

# ===================================
# Auto-Update Configuration (Private Repos Only)
# ===================================

# GitHub Token for Auto-Updates (read-only bot account)
# Only needed if using PRIVATE GitHub repository
# Get from: https://github.com/settings/tokens (using bot account)
# Scopes needed: repo (read access only)
GH_UPDATE_TOKEN=ghp_your_readonly_bot_token_here

# ===================================
# Build Configuration
# ===================================

# Environment
NODE_ENV=production

# Platform (leave empty for all)
# Options: mac, win, linux
BUILD_PLATFORM=

# ===================================
# Notes
# ===================================

# GH_TOKEN - Used ONLY when building/publishing releases
#   - Should have WRITE access
#   - Keep secret on your build machine
#   - Never commit to git
#
# GH_UPDATE_TOKEN - Used by the APP to check for updates
#   - Should be READ-ONLY
#   - From a BOT account (not your personal account)
#   - Gets embedded in the built app
#   - Safe to share (read-only, can only download releases)
